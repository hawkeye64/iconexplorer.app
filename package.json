{
  "name": "iconexplorer.app",
  "version": "3.1.0",
  "private": true,
  "description": "Icon Explorer application for Quasar Framework SVG icons. 140k+ searchable icons and growing.",
  "author": "Jeff Galbraith <jeff@quasar.dev>",
  "type": "module",
  "scripts": {
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "generate:icon-sets": "node scripts/generate-icon-sets.mjs",
    "typecheck": "pnpm generate:icon-sets && vue-tsc --noEmit --pretty false",
    "test": "echo \"No test specified\" && exit 0",
    "dev": "pnpm generate:icon-sets && quasar dev",
    "build": "pnpm generate:icon-sets && quasar build",
    "postinstall": "quasar prepare"
  },
  "dependencies": {
    "@quasar/extras": "^1.18.0",
    "@quasar/quasar-ui-qmarkdown": "3.0.0-beta.0",
    "pinia": "^3.0.4",
    "quasar": "^2.19.3",
    "quasar-extras-svg-icons": "3.0.0-beta.1",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@quasar/app-vite": "3.0.0-beta.21",
    "@quasar/quasar-app-extension-qmarkdown": "3.0.0-beta.0",
    "@types/node": "^25.9.1",
    "autoprefixer": "^10.5.0",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "~5.9.3",
    "vite-plugin-checker": "^0.13.0",
    "vue-tsc": "^3.3.1"
  },
  "engines": {
    "node": ">=22.13",
    "pnpm": ">=11.1.0"
  },
  "packageManager": "pnpm@11.1.0",
  "productName": "Icon Explorer for Quasar Framework SVG Icons"
}
